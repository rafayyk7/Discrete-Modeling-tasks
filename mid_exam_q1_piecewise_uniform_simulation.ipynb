import numpy as np

# Number of samples
N = 100000

# Probabilities of each region
p1 = 1/3   # region [0, 2]
p2 = 1/24   # region (2, 10]

# Generate uniform random numbers
U = np.random.rand(N)

# Initialize samples
X = np.zeros(N)

# Generate samples based on region probabilities
# For U <= p1, pick from Uniform(0, 2)
# For U > p1, pick from Uniform(2, 10)
region1 = U <= p1
region2 = ~region1

X[region1] = np.random.uniform(0, 2, np.sum(region1))
X[region2] = np.random.uniform(2, 10, np.sum(region2))

# Compute simulated mean
simulated_mean = np.mean(X)

# Theoretical mean
theoretical_mean = 2.6667

print("----- Problem 1 Results -----")
print(f"Theoretical Mean of X: {theoretical_mean:.4f}")
print(f"Simulated Mean of X:   {simulated_mean:.4f}")
print(f"Difference:            {abs(simulated_mean - theoretical_mean):.4e}")
