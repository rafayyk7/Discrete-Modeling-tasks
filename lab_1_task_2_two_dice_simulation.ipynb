import numpy as np
import matplotlib.pyplot as plt


n_rolls = 10000
die1 = np.random.randint(1, 7, size=n_rolls)
die2 = np.random.randint(1, 7, size=n_rolls)


outcomes = list(zip(die1, die2))


counts = {}
for i in range(1, 7):
    for j in range(1, 7):
        counts[(i, j)] = outcomes.count((i, j))


probabilities = {outcome: count / n_rolls for outcome, count in counts.items()}


labels = [str(outcome) for outcome in probabilities.keys()]
probs = list(probabilities.values())

plt.figure(figsize=(12, 6))
plt.bar(labels, probs)
plt.xticks(rotation=90)
plt.xlabel("Dice Outcomes (Die1, Die2)")
plt.ylabel("Probability")
plt.title("Probabilities of Two Dice Outcomes (10,000 rolls)")
plt.show()
