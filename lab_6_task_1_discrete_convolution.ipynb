import numpy as np

# -----------------------------------
# Define the signals
# -----------------------------------
x = []
for n in range(0, 11):      # 0 <= n <= 10
    x.append(n*n)           # x[n] = n^2

h = []
for n in range(0, 6):       # 0 <= n <= 5
    h.append(n)             # h[n] = n

Nx = len(x)
Nh = len(h)

# Output length
Ny = Nx + Nh - 1

# -----------------------------------
# Manual convolution
# -----------------------------------
y_manual = [0] * Ny

for n in range(Ny):
    for k in range(Nx):
        if (n - k) >= 0 and (n - k) < Nh:
            y_manual[n] += x[k] * h[n - k]

# -----------------------------------
# Built-in convolution (for comparison)
# -----------------------------------

y_conv = np.convolve(x, h)

# -----------------------------------
# Print results
# -----------------------------------
print("Manual convolution result:")
print(y_manual)

print("\nBuilt-in numpy.convolve result:")
# Corrected line: .tolist() converts the numpy array to a clean Python list
print(y_conv.tolist())
